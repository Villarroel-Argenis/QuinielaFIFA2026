@page "/login"
@page "/"
@rendermode InteractiveServer
@attribute [AllowAnonymous]

<PageTitle>Quiniela FIFA 2026</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="3" Class="pa-8">
        <div class="d-flex justify-center mb-4">
            <MudText Typo="Typo.h4" Align="Align.Center">
                🏆 Quiniela FIFA 2026
            </MudText>
        </div>
        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-6 mud-text-secondary">
            11 junio – 19 julio 2026
        </MudText>

        <MudTextField @bind-Value="_username"
                      Label="Correo electrónico"
                      Variant="Variant.Outlined"
                      InputType="InputType.Email"
                      Class="mb-4"
                      OnKeyUp="OnKeyUp" />

        <MudTextField @bind-Value="_password"
                      Label="Contraseña"
                      Variant="Variant.Outlined"
                      InputType="InputType.Password"
                      Class="mb-4"
                      OnKeyUp="OnKeyUp" />

        @if (_isRegister)
        {
            <MudTextField @bind-Value="_confirmPassword"
                          Label="Confirmar contraseña"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Class="mb-4"
                          OnKeyUp="OnKeyUp" />
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="HandleSubmit"
                   Disabled="_loading">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(_isRegister ? "Registrarme" : "Entrar")
        </MudButton>

        <MudButton Variant="Variant.Text"
                   FullWidth="true"
                   Class="mt-2"
                   OnClick='() => { _isRegister = !_isRegister; _error = ""; }'>
            @(_isRegister ? "¿Ya tienes cuenta? Entrar" : "¿Primera vez? Registrarme")
        </MudButton>

    </MudPaper>
</MudContainer>