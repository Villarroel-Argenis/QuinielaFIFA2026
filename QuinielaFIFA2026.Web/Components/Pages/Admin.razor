@page "/admin"
@rendermode InteractiveServer

<PageTitle>Panel Administrador</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h5" Class="mb-4">Panel de Administrador</MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">

        <!-- TAB 1: Generar Lotes -->
        <MudTabPanel Text="Generar Planillas" Icon="@Icons.Material.Filled.Add">
            <MudContainer Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">Generar lote de planillas</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudNumericField @bind-Value="_cantidad"
                                         Label="Cantidad de planillas"
                                         Variant="Variant.Outlined"
                                         Min="1" Max="100" />
                    </MudItem>
                    <MudItem xs="12" sm="4" Class="d-flex align-center">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="GenerarPlanillas"
                                   Disabled="_generando"
                                   StartIcon="@Icons.Material.Filled.Print">
                            Generar Lote
                        </MudButton>
                    </MudItem>
                </MudGrid>

                @if (_ultimoLote is not null)
                {
                    <MudAlert Severity="Severity.Success" Class="mt-4">
                        Lote <strong>@_ultimoLote.Codigo</strong> generado con @_ultimoLote.Planillas.Count planillas.
                    </MudAlert>
                }

                @if (_lotes.Any())
                {
                    <MudText Typo="Typo.h6" Class="mt-6 mb-3">Lotes generados</MudText>
                    @foreach (var lote in _lotes)
                    {
                        <MudExpansionPanel Class="mb-2">
                            <TitleContent>
                                <div class="d-flex align-center gap-4">
                                    <MudText Typo="Typo.subtitle1"><strong>@lote.Codigo</strong></MudText>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                                        @lote.Cantidad planillas
                                    </MudChip>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                        @lote.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </MudText>
                                    <MudButton Variant="Variant.Outlined"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.PictureAsPdf"
                                               Href="@($"/api/lote/{lote.Id}/pdf")"
                                               Target="_blank">
                                        Imprimir PDF
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               StartIcon="@Icons.Material.Filled.Delete"
                                               OnClick="() => ConfirmarEliminarLote(lote)">
                                        Eliminar
                                    </MudButton>
                                </div>
                            </TitleContent>
                            <ChildContent>
                                <MudTable Items="lote.Planillas" Hover="true" Striped="true" Dense="true">
                                    <HeaderContent>
                                        <MudTh>Código</MudTh>
                                        <MudTh>Estado</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.Codigo</MudTd>
                                        <MudTd>
                                            @if (context.IsAssigned)
                                            {
                                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Asignada</MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Color="Color.Warning" Size="Size.Small">Sin asignar</MudChip>
                                            }
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                }
            </MudContainer>
        </MudTabPanel>

        <!-- TAB 2: Planillas Asignadas -->
        <MudTabPanel Text="Planillas Asignadas" Icon="@Icons.Material.Filled.People">
            <MudContainer Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">Planillas vinculadas a usuarios</MudText>
                @if (_planillasAsignadas is null)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (!_planillasAsignadas.Any())
                {
                    <MudAlert Severity="Severity.Info">No hay planillas asignadas aún.</MudAlert>
                }
                else
                {
                    <MudTable Items="_planillasAsignadas" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>Código</MudTh>
                            <MudTh>Lote</MudTh>
                            <MudTh>Usuario</MudTh>
                            <MudTh>Fecha asignación</MudTh>
                            <MudTh>Acción</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Codigo</MudTd>
                            <MudTd>@context.Lote?.Codigo</MudTd>
                            <MudTd>@context.User?.Username</MudTd>
                            <MudTd>@context.AssignedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                            <MudTd>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="() => ConfirmarDesvincular(context)">
                                    Desvincular
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudContainer>
        </MudTabPanel>

        <!-- TAB 3: Resultados -->
        <MudTabPanel Text="Resultados" Icon="@Icons.Material.Filled.SportsSoccer">
            <MudContainer Class="pa-4">
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">Ingresar resultados oficiales</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.RestartAlt"
                               OnClick='() => _showConfirmResetAll = true'>
                        Resetear todos
                    </MudButton>
                </div>

                @foreach (var grupo in _allMatches
                    .OrderBy(m => m.Match.MatchDateUtc)
                    .GroupBy(m => m.Match.MatchDateUtc.Date)
                    .Select(g => (Fecha: g.Key, Partidos: g.ToList())))
                {
                    <div class="mt-4 mb-2 d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday"
                                 Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle1"
                                 Style="font-weight:600; text-transform:capitalize;">
                            @grupo.Fecha.ToString("dddd d 'de' MMMM yyyy",
                                new System.Globalization.CultureInfo("es-ES"))
                        </MudText>
                    </div>
                    <MudDivider Class="mb-3" />
                    <MudTable Items="@grupo.Partidos" Dense="true" Hover="true"
                              Striped="true" Class="mb-4">
                        <HeaderContent>
                            <MudTh>Partido</MudTh>
                            <MudTh Style="text-align:right">Local</MudTh>
                            <MudTh Style="text-align:center"></MudTh>
                            <MudTh>Visitante</MudTh>
                            <MudTh Style="text-align:center">L</MudTh>
                            <MudTh Style="text-align:center">E</MudTh>
                            <MudTh Style="text-align:center">V</MudTh>
                            <MudTh Style="text-align:center"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <div>@context.Match.MatchNumber</div>
                                <div class="mud-text-secondary" style="font-size:0.75rem">
                                    @context.Match.MatchDateUtc.ToString("HH:mm")
                                </div>
                            </MudTd>

                            <!-- Local -->
                            <MudTd Style="text-align:right; font-size: 1.4rem">
                                @if (!string.IsNullOrEmpty(context.Match.HomeSlot) && context.Match.HomeTeam == "TBD")
                                {
                                    var resolvedHome = ResolveOfficialTeam(context.Match.HomeSlot);
                                    <div class="mud-text-secondary" style="font-size:0.75rem">
                                        @SlotService.GetDescripcion(context.Match.HomeSlot)
                                    </div>
                                    @if (!string.IsNullOrEmpty(resolvedHome))
                                    {
                                        <div class="d-flex align-center justify-end gap-1">
                                            <img src="@SlotService.GetFlagUrl(resolvedHome)"
                                                 style="width:24px;height:18px;object-fit:cover;" />
                                            <span>@resolvedHome</span>
                                        </div>
                                    }
                                    else if (!context.Match.HomeSlot.StartsWith("W") && !context.Match.HomeSlot.StartsWith("RU"))
                                    {
                                        <MudSelect T="string"
                                                   ValueChanged='v => AsignarEquipo(context.Match.Id, true, v)'
                                                   Dense="true" Margin="Margin.Dense"
                                                   Placeholder="@SlotService.GetDescripcion(context.Match.HomeSlot)">
                                            @foreach (var eq in GetEquiposSlot(context.Match.HomeSlot))
                                            {
                                                <MudSelectItem Value="@eq">@eq</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        <span class="mud-text-secondary" style="font-size:0.85rem">
                                            Por definir
                                        </span>
                                    }
                                }
                                else
                                {
                                    <div class="d-flex align-center justify-end gap-1">
                                        <img src="@GetDisplayFlagUrl(context.Match, true)"
                                             style="width:24px;height:18px;object-fit:cover;" />
                                        <span>@GetDisplayTeam(context.Match, true)</span>
                                        @if (!string.IsNullOrEmpty(context.Match.HomeSlot))
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                           Size="Size.Small"
                                                           OnClick='() => AsignarEquipo(context.Match.Id, true, "TBD")' />
                                        }
                                    </div>
                                }
                            </MudTd>

                            <MudTd Style="text-align:center; color:#2E7D32; font-weight:bold;">@@</MudTd>

                            <!-- Visitante -->
                            <MudTd style="font-size: 1.4rem">
                                @if (!string.IsNullOrEmpty(context.Match.AwaySlot) && context.Match.AwayTeam == "TBD")
                                {
                                    var resolvedAway = ResolveOfficialTeam(context.Match.AwaySlot);
                                    <div class="mud-text-secondary" style="font-size:0.75rem">
                                        @SlotService.GetDescripcion(context.Match.AwaySlot)
                                    </div>
                                    @if (!string.IsNullOrEmpty(resolvedAway))
                                    {
                                        <div class="d-flex align-center gap-1">
                                            <img src="@SlotService.GetFlagUrl(resolvedAway)"
                                                 style="width:24px;height:18px;object-fit:cover;" />
                                            <span>@resolvedAway</span>
                                        </div>
                                    }
                                    else if (!context.Match.AwaySlot.StartsWith("W") && !context.Match.AwaySlot.StartsWith("RU"))
                                    {
                                        <MudSelect T="string"
                                                   ValueChanged='v => AsignarEquipo(context.Match.Id, false, v)'
                                                   Dense="true" Margin="Margin.Dense"
                                                   Placeholder="@SlotService.GetDescripcion(context.Match.AwaySlot)">
                                            @foreach (var eq in GetEquiposSlot(context.Match.AwaySlot))
                                            {
                                                <MudSelectItem Value="@eq">@eq</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        <span class="mud-text-secondary" style="font-size:0.85rem">
                                            Por definir
                                        </span>
                                    }
                                }
                                else
                                {
                                    <div class="d-flex align-center gap-1">
                                        <img src="@GetDisplayFlagUrl(context.Match, false)"
                                             style="width:24px;height:18px;object-fit:cover;" />
                                        <span>@GetDisplayTeam(context.Match, false)</span>
                                        @if (!string.IsNullOrEmpty(context.Match.AwaySlot))
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                           Size="Size.Small"
                                                           OnClick='() => AsignarEquipo(context.Match.Id, false, "TBD")' />
                                        }
                                    </div>
                                }
                            </MudTd>

                            <!-- L -->
                            <MudTd Style="text-align:center">
                                <MudButton Variant="@(context.Result?.Result == "home" ? Variant.Filled : Variant.Outlined)"
                                           Color="Color.Primary" Size="Size.Small"
                                           OnClick='() => GuardarResultado(context.Match.Id, "home")'>
                                    L
                                </MudButton>
                            </MudTd>

                            <!-- E -->
                            <MudTd Style="text-align:center">
                                @if (context.Match.AllowDraw)
                                {
                                    <MudButton Variant="@(context.Result?.Result == "draw" ? Variant.Filled : Variant.Outlined)"
                                               Color="Color.Secondary" Size="Size.Small"
                                               OnClick='() => GuardarResultado(context.Match.Id, "draw")'>
                                        E
                                    </MudButton>
                                }
                            </MudTd>

                            <!-- V -->
                            <MudTd Style="text-align:center">
                                <MudButton Variant="@(context.Result?.Result == "away" ? Variant.Filled : Variant.Outlined)"
                                           Color="Color.Error" Size="Size.Small"
                                           OnClick='() => GuardarResultado(context.Match.Id, "away")'>
                                    V
                                </MudButton>
                            </MudTd>

                            <!-- Reset individual -->
                            <MudTd Style="text-align:center">
                                @if (context.Result != null)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.RestartAlt"
                                                   Size="Size.Small" Color="Color.Warning"
                                                   OnClick='() => ResetearResultado(context.Match.Id)' />
                                }
                            </MudTd>

                        </RowTemplate>
                    </MudTable>
                }
            </MudContainer>
        </MudTabPanel>
     </MudTabs>
</MudContainer>

<!-- Dialog resetear todos -->
<MudDialog @bind-Visible="_showConfirmResetAll">
    <TitleContent><MudText Typo="Typo.h6">Resetear todos los resultados</MudText></TitleContent>
    <DialogContent>
        <MudText>
            ¿Estás seguro que deseas eliminar <strong>todos</strong> los resultados ingresados?
            Esta acción no se puede deshacer.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showConfirmResetAll = false">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ResetearTodosLosResultados">
            Resetear todo
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showConfirmLote">
    <TitleContent>
        <MudText Typo="Typo.h6">Eliminar lote</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            ¿Estás seguro que deseas eliminar el lote <strong>@_loteSeleccionado?.Codigo</strong>
            con <strong>@_loteSeleccionado?.Cantidad</strong> planillas?
        </MudText>
        @if (!string.IsNullOrEmpty(_errorLote))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_errorLote</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick='() => { _showConfirmLote = false; _errorLote = ""; }'>Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="EjecutarEliminarLote">
            Eliminar
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showConfirm">
    <TitleContent>
        <MudText Typo="Typo.h6">Confirmar desvinculación</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            ¿Estás seguro que deseas desvincular la planilla <strong>@_planillaSeleccionada?.Codigo</strong>
            del usuario <strong>@_planillaSeleccionada?.User?.Username</strong>?
            Se borrarán todas sus predicciones.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showConfirm = false">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="EjecutarDesvincular">
            Desvincular
        </MudButton>
    </DialogActions>
</MudDialog>