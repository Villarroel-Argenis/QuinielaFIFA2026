@inherits LayoutComponentBase
@inject NavigationManager Nav

<MudThemeProvider Theme="AppTheme.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized Context="auth">
        <MudLayout>
            <MudAppBar Elevation="1" Color="Color.Primary">
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Color="Color.Inherit"
                               Edge="Edge.Start"
                               OnClick="ToggleDrawer" />
                <svg xmlns="http://www.w3.org/2000/svg" height="32" viewBox="0 0 24 24" fill="white" class="mr-2">
                    <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94A5.01 5.01 0 0011 15.9V18H9v2h6v-2h-2v-2.1a5.01 5.01 0 003.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z" />
                </svg>
                <MudText Typo="Typo.h6" Style="color: white;">Quiniela FIFA 2026</MudText>
                <MudSpacer />
                <img src="/images/logo-vinccler.svg" alt="Vinccler" style="height: 55px;" class="mr-3" />
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="DrawerVariant.Temporary">
                <MudDrawerHeader>
                    <MudText Typo="Typo.subtitle1" Class="mt-2">
                        <strong>@auth.User.Identity?.Name</strong>
                    </MudText>
                </MudDrawerHeader>
                <MudNavMenu>
                    <MudNavLink Href="/mis-planillas" Icon="@Icons.Material.Filled.Assignment"
                                Match="NavLinkMatch.All">
                        Mis Planillas
                    </MudNavLink>
                    <MudNavLink Href="/tabla" Icon="@Icons.Material.Filled.Leaderboard"
                                Match="NavLinkMatch.All">
                        Tabla General
                    </MudNavLink>
                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <MudDivider Class="my-2" />
                            <MudNavLink Href="/admin" Icon="@Icons.Material.Filled.AdminPanelSettings"
                                        Match="NavLinkMatch.All">
                                Administrador
                            </MudNavLink>
                        </Authorized>
                    </AuthorizeView>
                    <MudDivider Class="my-2" />
                    <MudNavLink Icon="@Icons.Material.Filled.Logout" OnClick="Logout">
                        Cerrar Sesión
                    </MudNavLink>
                </MudNavMenu>
            </MudDrawer>

            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </Authorized>

    <NotAuthorized>
        <MudLayout>
            <MudAppBar Elevation="1" Color="Color.Primary">
                <svg xmlns="http://www.w3.org/2000/svg" height="32" viewBox="0 0 24 24" fill="white" class="mr-2">
                    <path d="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94A5.01 5.01 0 0011 15.9V18H9v2h6v-2h-2v-2.1a5.01 5.01 0 003.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z" />
                </svg>
                <MudText Typo="Typo.h6" Style="color: white;">Quiniela FIFA 2026</MudText>
                <MudSpacer />
                <img src="/images/logo-vinccler.svg" alt="Vinccler" style="height: 55px;" class="mr-3" />
            </MudAppBar>
            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = false;
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void Logout() => Nav.NavigateTo("/api/auth/signout", forceLoad: true);
}